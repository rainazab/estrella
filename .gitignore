# --- secrets / env ---
.env
.env.*
!.env.example
!*.env.example

# --- python local state ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# --- raw and generated data (confidential) ---
# Damm Excel exports never leave the local machine.
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/output/*
!data/output/.gitkeep

# Spreadsheet / tabular formats — never commit, regardless of folder.
*.xlsx
*.xls
*.xlsm
*.XLSX
*.csv
*.parquet

# --- OS / editor noise ---
.DS_Store
.idea/
.vscode/
