# --- secrets / env ---
.env
.env.*
!.env.example
!*.env.example

# --- python local state ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# --- raw and generated data (confidential) ---
# Damm Excel exports never leave the local machine.
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/output/*
!data/output/.gitkeep

# Spreadsheet / tabular formats — never commit, regardless of folder.
*.xlsx
*.xls
*.xlsm
*.XLSX
*.csv
*.parquet

# --- frontend (Node / Vite / Next / generic JS bundlers) ---
node_modules/
.next/
.nuxt/
.vite/
.vite-cache/
dist/
build/
out/
coverage/
.turbo/
.parcel-cache/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS / editor noise ---
.DS_Store
.idea/
.vscode/
