# LineWise backend env vars (all optional — CLI flags take precedence).
# Copy to .env if you want to override defaults without retyping flags.

# Override the location of the raw Excel exports.
# LINEWISE_RAW_DIR=data/raw

# Override the directory for intermediate / report artifacts.
# LINEWISE_PROCESSED_DIR=data/processed

# Override the directory for the generated data.json.
# LINEWISE_OUTPUT_DIR=data/output

# --- External integrations ---
# Cala (https://console.cala.ai/api-keys) — enables live world-signals
# refresh. Without this set, POST /signals/refresh just re-serves the
# seed file and the demo runs offline with citation-shaped sample data.
# CALA_API_KEY=
